{
  "name": "ryze-uniswapx-filler",
  "version": "0.0.0",
  "private": true,
  "description": "Off-chain filler for UniswapX Priority Orders on Base, sourcing liquidity from Ryze SmartShield pools.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "dry-run": "MODE=dryrun node --import tsx src/main.ts",
    "shadow": "MODE=shadow node --import tsx src/main.ts",
    "fork-fill": "node --import tsx src/forkFill.ts",
    "live": "MODE=live node --import tsx src/main.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@uniswap/uniswapx-sdk": "^3.0.10",
    "ethers": "^6.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
